name: Build K2 OpenWrt 24.10.5 Chinese UI

on:
  workflow_dispatch:
    inputs:
      version:
        description: 'OpenWrt version'
        required: true
        default: '24.10.5'
        type: choice
        options:
          - '24.10.5'

jobs:
  build:
    runs-on: ubuntu-22.04
    timeout-minutes: 360

    steps:
      - name: Install dependencies
        run: |
          sudo apt update
          sudo apt install -y build-essential clang flex bison g++ gawk \
          gcc-multilib g++-multilib gettext git libncurses5-dev libssl-dev \
          python3-setuptools rsync swig unzip zlib1g-dev file wget subversion \
          libelf-dev autoconf automake libtool curl

      - name: Checkout
        uses: actions/checkout@v4

      - name: Download OpenWrt 24.10.5 source
        run: |
          git clone --depth 1 -b openwrt-24.10 https://github.com/openwrt/openwrt.git
          cd openwrt
          git fetch --tags
          git checkout v24.10.5
          echo "✅ OpenWrt 24.10.5 source downloaded"

      - name: Modify DTS for 16MB flash (0x50000 layout)
        run: |
          cd openwrt
          
          # OpenWrt 24.10 的设备树路径可能不同
          DTS_FILE="target/linux/ramips/dts/mt7620a_phicomm_k2.dts"
          DTS_FILE_ALT="target/linux/ramips/dts/mt7620n_phicomm_k2.dts"
          DTS_FILE_NEW="target/linux/ramips/dts/ralink,mt7620a-phicomm,k2.dts"
          
          MODIFIED=0
          
          # 尝试多个可能的DTS文件路径
          for file in "$DTS_FILE" "$DTS_FILE_ALT" "$DTS_FILE_NEW"; do
            if [ -f "$file" ]; then
              echo "找到DTS文件: $file"
              cp "$file" "${file}.bak"
              # 修改firmware分区从8M到16M
              sed -i 's/reg = <0x50000 0xfb0000>/reg = <0x50000 0x1fb0000>/' "$file"
              echo "✅ 修改完成: firmware分区 0x50000 -> 0x1fb0000 (16MB)"
              grep -A3 "partition@50000" "$file" || grep -A3 "firmware" "$file" | head -5
              MODIFIED=1
              break
            fi
          done
          
          if [ $MODIFIED -eq 0 ]; then
            echo "❌ 错误: 未找到K2的DTS文件"
            # 列出所有可能的DTS文件供调试
            find target/linux/ramips/dts -name "*k2*" -o -name "*phicomm*" 2>/dev/null || true
            exit 1
          fi

      - name: Verify 16MB modification
        run: |
          cd openwrt
          echo "🔍 验证16MB闪存修改:"
          
          # 查找修改后的DTS文件
          DTS_FILE=$(find target/linux/ramips/dts -name "*k2*" -o -name "*phicomm*" | head -1)
          if [ -f "$DTS_FILE" ]; then
            echo "检查文件: $DTS_FILE"
            if grep -q "0x1fb0000" "$DTS_FILE"; then
              echo "✅ 16MB修改已确认 (0x1fb0000)"
              grep -B2 -A2 "0x1fb0000" "$DTS_FILE" | head -10
            else
              echo "❌ 16MB修改失败！仍然是8MB大小"
              grep -A5 "firmware" "$DTS_FILE" || true
              exit 1
            fi
          fi

      - name: Modify Makefile for 16MB image size
        run: |
          cd openwrt
          
          # OpenWrt 24.10 的Makefile路径
          MK_FILE="target/linux/ramips/image/mt7620.mk"
          
          if [ -f "$MK_FILE" ]; then
            echo "修改文件: $MK_FILE"
            # 备份原文件
            cp "$MK_FILE" "${MK_FILE}.bak"
            # 修改IMAGE_SIZE为16MB
            sed -i '/define Device\/phicomm_k2/,/endef/ s/IMAGE_SIZE := .*/IMAGE_SIZE := 16064k/' "$MK_FILE"
            echo "✅ IMAGE_SIZE修改完成"
            # 显示修改结果
            sed -n '/define Device\/phicomm_k2/,/endef/p' "$MK_FILE" | grep "IMAGE_SIZE"
          else
            echo "❌ 错误: 未找到mt7620.mk文件"
            exit 1
          fi

      - name: Create config file (Chinese UI + WireGuard + ZeroTier)
        run: |
          cd openwrt
          
          cat > .config << 'EOF'
# Target platform
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_phicomm_k2=y
CONFIG_TARGET_DEVICE_ramips_mt7620_DEVICE_phicomm_k2=y

# Kernel options
CONFIG_KERNEL_PRINTK=y
CONFIG_KERNEL_SWAP=y

# 16MB flash settings
CONFIG_TARGET_ROOTFS_PARTSIZE=16
CONFIG_TARGET_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_SPLIT_FIRMWARE=y

# LuCI with Chinese language support
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y

# Themes with Chinese support
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-material=y
CONFIG_PACKAGE_luci-i18n-material-zh-cn=y

# WireGuard (built-in in kernel 5.15+)
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-i18n-wireguard-zh-cn=y

# ZeroTier
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# Wireless drivers
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76x0e=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_MT76_LEDS=y

# Network tools
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-nat-extra=y

# System utilities
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_coreutils=y

# IPv6 and NAT helpers
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-raw=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y
EOF

          echo "✅ .config file created"
          make defconfig
          
          # Show selected packages
          echo "Selected Chinese language packages:"
          grep luci-i18n .config | grep -v "not set" || true

      - name: Update feeds
        run: |
          cd openwrt
          ./scripts/feeds update -a
          ./scripts/feeds install -a

      - name: Download packages
        run: |
          cd openwrt
          make download -j8

      - name: Compile firmware
        run: |
          cd openwrt
          echo "Starting compilation for OpenWrt 24.10.5..."
          echo "Start time: $(date)"
          
          # Build toolchain
          make tools/compile -j$(nproc)
          make toolchain/compile -j$(nproc)
          
          # Build firmware
          make -j$(nproc) V=s || make -j1 V=s
          
          echo "End time: $(date)"

      - name: Organize firmware files
        run: |
          cd openwrt
          mkdir -p firmware
          
          # Find and copy firmware files
          find bin/targets/ -name "*.bin" -exec cp {} firmware/ \;
          
          cd firmware
          # Rename files for clarity
          for f in *.bin; do
            if [ -f "$f" ]; then
              if [[ "$f" == *"sysupgrade"* ]]; then
                mv "$f" "K2-16M-24.10.5-ChineseUI-sysupgrade.bin" 2>/dev/null || true
              elif [[ "$f" == *"initramfs"* ]]; then
                mv "$f" "K2-16M-24.10.5-ChineseUI-initramfs.bin" 2>/dev/null || true
              fi
            fi
          done
          
          # Create checksums
          md5sum *.bin > md5sums.txt 2>/dev/null || true
          
          echo "Firmware files:"
          ls -la

      - name: Create Chinese README
        run: |
          cd openwrt/firmware
          
          cat > README.txt << 'EOF'
================================================
斐讯K2 OpenWrt 24.10.5 固件 (中文UI版)
================================================

【固件信息】
- 版本: OpenWrt 24.10.5
- 内核: Linux 5.15.x
- 机型: 斐讯K2 (A1/A2) - 必须硬改16M闪存
- 闪存布局: 公版布局 (firmware分区起始: 0x50000)
- 界面: 简体中文 (默认)
- 集成: WireGuard + ZeroTier

【主要特性】
- ✅ WireGuard VPN (内核级支持 + 中文界面)
- ✅ ZeroTier 组网 (客户端 + 中文界面)
- ✅ 中文语言包 (完整翻译)
- ✅ 2.4GHz & 5GHz 无线驱动
- ✅ 网络工具 (iperf3, tcpdump, iptables)
- ✅ 系统工具 (htop, nano, curl)

【刷机步骤】
1. 进入Breed (按住Reset键上电)
2. 选择"固件更新"
3. 选择 *-sysupgrade.bin 文件
4. ⚠️ 闪存布局必须选"公版"或"0x50000"
5. 点击上传并确认
6. 等待自动重启 (约2分钟)

【默认配置】
- 管理地址: http://192.168.1.1
- 用户名: root
- 密码: (空)
- WiFi: 默认关闭，请手动开启

【注意事项】
- 本固件仅适用于硬改16M闪存的K2
- 原厂8M闪存请勿刷入
- 刷机前建议在Breed中备份编程器固件

================================================
编译时间: $(date)
================================================
EOF

      - name: Upload firmware artifacts
        uses: actions/upload-artifact@v4
        with:
          name: K2-16M-24.10.5-ChineseUI
          path: openwrt/firmware/
          retention-days: 30

      - name: Create Release
        uses: softprops/action-gh-release@v1
        if: github.event_name == 'workflow_dispatch'
        with:
          tag_name: K2-24.10.5-${{ github.run_number }}
          name: K2 OpenWrt 24.10.5 Chinese UI (16MB)
          body: |
            ## 🎉 斐讯K2 OpenWrt 24.10.5 固件 - 中文UI版
            
            ### 📌 版本信息
            - **OpenWrt版本**: 24.10.5
            - **内核版本**: Linux 5.15.x
            - **适用机型**: 斐讯K2 (A1/A2) - **必须硬改16M闪存**
            - **闪存布局**: 公版布局 (firmware分区起始: 0x50000)
            
            ### ✨ 集成功能
            - **WireGuard VPN** (内核模块 + 中文界面)
            - **ZeroTier** (客户端 + 中文界面)
            - **完整中文语言包** (LuCI界面100%中文)
            - **无线驱动**: 2.4GHz & 5GHz 完整支持
            
            ### ⚠️ 重要提示
            在Breed中刷机时，**闪存布局必须选择"公版"或"0x50000"**！
            
            ### 🔧 默认配置
            - IP: 192.168.1.1
            - 用户名: root
            - 密码: (空)
            
            ### 📥 下载
            附件中包含两个文件:
            - `*-sysupgrade.bin`: 正常刷机使用
            - `*-initramfs.bin`: 临时系统(仅测试用)
          files: openwrt/firmware/*.bin
          draft: false
          prerelease: false
